{
  "name": "agentic-researcher",
  "version": "0.4.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "description": "Single-install native Obsidian agentic research, code, companion, and integrations plugin.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "check:plugin-catalog": "node scripts/plugin-catalog.mjs",
    "build": "npm run check:plugin-catalog && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node scripts/run-node-tests.mjs",
    "test:companion": "python -m pytest companion/tests -q",
    "check:path-hygiene": "node scripts/check-path-hygiene.mjs",
    "test:ci": "npm run check:path-hygiene && npm test && npm run build",
    "sync:test-vault": "node scripts/sync-test-vault.mjs",
    "e2e:preflight": "node scripts/e2e-preflight.mjs",
    "test:e2e": "node scripts/run-e2e-exclusive.mjs --real-ai --project=daily-use-research",
    "test:e2e:mock": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=deterministic-core-mock",
    "test:e2e:daily-use-note": "node scripts/run-disposable-daily-use-note-e2e.mjs",
    "test:e2e:daily-use:connections": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-connections",
    "test:e2e:daily-use:memory-reflex": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-memory-reflex",
    "test:e2e:daily-use:focused": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-connections --project=daily-use-memory-reflex --project=daily-use-code --project=daily-use-linear --project=daily-use-github",
    "test:e2e:daily-use": "npm run test:e2e:daily-use-note && npm run test:e2e:daily-use:focused",
    "test:e2e:daily-use:mock": "npm run test:e2e:daily-use",
    "test:e2e:daily-use:live-model": "node scripts/run-e2e-exclusive.mjs --real-ai --project=daily-use-research --grep=DU-02",
    "test:e2e:daily-use:code": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-code --grep=DU-03",
    "test:e2e:daily-use:languages": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-code --grep=LANG-01",
    "test:e2e:daily-use:code:live": "node scripts/run-e2e-exclusive.mjs --real-ai --project=daily-use-code-live",
    "test:e2e:daily-use:linear": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-linear --grep=DU-04",
    "test:e2e:daily-use:github": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-github --grep=DU-05",
    "test:e2e:daily-use:compound": "node scripts/run-e2e-exclusive.mjs --real-ai --project=daily-use-compound --grep=DU-06",
    "test:e2e:daily-use:checkers": "node scripts/run-e2e-exclusive.mjs --real-ai --project=daily-use-compound --grep=\"DU-06 checkers\"",
    "test:e2e:integration": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=integration-mock --project=integration-mock-legacy",
    "test:e2e:sandbox": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-code",
    "test:e2e:companion": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=companion-restart",
    "test:e2e:deterministic-matrix": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=daily-use-connections --project=daily-use-note --project=daily-use-memory-reflex --project=daily-use-code --project=daily-use-linear --project=daily-use-github --project=deterministic-core-mock --project=integration-mock-legacy --project=companion-restart",
    "test:e2e:real": "npm run test:e2e",
    "test:e2e:real:soak": "node scripts/run-e2e-exclusive.mjs --real-ai --project=real-ai-soak",
    "test:e2e:long": "npm run test:e2e:real:soak",
    "test:e2e:real:long": "npm run test:e2e:real:soak",
    "test:e2e:real:xhigh": "npm run test:e2e:real:soak",
    "test:e2e:provider-canary": "node scripts/run-e2e-exclusive.mjs --real-ai --project=provider-canary",
    "test:e2e:release-vertical": "node scripts/run-e2e-exclusive.mjs --real-ai --project=daily-use-compound",
    "test:e2e:live": "node scripts/run-e2e-exclusive.mjs --live-external --project=disposable-live-external",
    "test:e2e:configured-linear": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=configured-linear-live",
    "test:e2e:headed": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=deterministic-core-mock --headed",
    "test:e2e:real:headed": "node scripts/run-e2e-exclusive.mjs --real-ai --project=daily-use-research --headed"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "research"
  ],
  "author": "Josh",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.10",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.6.7",
    "tsx": "^4.23.0",
    "typescript": "^5.5.3"
  }
}
