{
  "name": "agentic-researcher",
  "version": "0.4.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "description": "Single-install native Obsidian agentic research, code, companion, and integrations plugin.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "check:plugin-catalog": "node scripts/plugin-catalog.mjs",
    "build": "npm run check:plugin-catalog && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node scripts/run-node-tests.mjs",
    "test:companion": "python -m pytest companion/tests -q",
    "check:path-hygiene": "node scripts/check-path-hygiene.mjs",
    "test:ci": "npm run check:path-hygiene && npm test && npm run build",
    "sync:test-vault": "node scripts/sync-test-vault.mjs",
    "e2e:preflight": "node scripts/e2e-preflight.mjs",
    "test:e2e": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=deterministic-core-mock",
    "test:e2e:mock": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=deterministic-core-mock",
    "test:e2e:integration": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=integration-mock --project=integration-mock-legacy",
    "test:e2e:sandbox": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=sandbox",
    "test:e2e:companion": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=companion-restart",
    "test:e2e:deterministic-matrix": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=deterministic-core-mock --project=integration-mock --project=integration-mock-legacy --project=sandbox --project=companion-restart",
    "test:e2e:real": "node scripts/run-e2e-exclusive.mjs --real-ai --project=real-ai",
    "test:e2e:long": "node scripts/run-e2e-exclusive.mjs --real-ai --project=real-ai --grep \"real ai\"",
    "test:e2e:real:long": "node scripts/run-e2e-exclusive.mjs --real-ai --project=real-ai --grep \"real ai\"",
    "test:e2e:real:xhigh": "node scripts/run-e2e-exclusive.mjs --real-ai --project=real-ai --grep \"real ai\"",
    "test:e2e:live": "node scripts/run-e2e-exclusive.mjs --live-external --project=disposable-live-external",
    "test:e2e:headed": "node scripts/run-e2e-exclusive.mjs --mock-ai --project=deterministic-core-mock --headed",
    "test:e2e:real:headed": "node scripts/run-e2e-exclusive.mjs --real-ai --project=real-ai --headed"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "research"
  ],
  "author": "Josh",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.10",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.6.7",
    "tsx": "^4.23.0",
    "typescript": "^5.5.3"
  }
}
